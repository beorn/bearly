{
  "name": "alien-resources",
  "version": "0.1.3",
  "description": "Async signal bridge for alien-signals — reactive resources with loading/error states and automatic cancellation",
  "keywords": [
    "alien-signals",
    "async",
    "cancellation",
    "createResource",
    "data-fetching",
    "fine-grained",
    "loading",
    "reactive",
    "resource",
    "signals",
    "solidjs",
    "suspense",
    "tanstack-query",
    "tc39-signals"
  ],
  "homepage": "https://github.com/beorn/bearly/tree/main/packages/alien-resources",
  "bugs": {
    "url": "https://github.com/beorn/bearly/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/bearly.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "tsdown": "^0.21.7"
  },
  "peerDependencies": {
    "alien-signals": ">=3.0.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  }
}
