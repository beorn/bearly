{
  "name": "alien-trees",
  "version": "0.1.0",
  "description": "Tree-scoped reactive aggregates (ancestors/descendants · some/count/reduce) for the alien-signals ecosystem",
  "keywords": [
    "alien-signals",
    "ancestors",
    "bevy",
    "changed",
    "computed",
    "derived",
    "descendants",
    "fine-grained",
    "hierarchy",
    "incremental",
    "materialized-view",
    "reactive",
    "signals",
    "solidjs",
    "sparse-index",
    "tc39-signals",
    "tree",
    "trees"
  ],
  "homepage": "https://github.com/beorn/bearly/tree/main/packages/alien-trees",
  "bugs": {
    "url": "https://github.com/beorn/bearly/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/bearly.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "alien-signals": "^3.1.2",
    "tsdown": "^0.21.7"
  },
  "peerDependencies": {
    "alien-signals": ">=3.0.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  }
}
