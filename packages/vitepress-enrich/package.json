{
  "name": "@bearly/vitepress-enrich",
  "version": "0.3.4",
  "description": "Glossary auto-linking, content linkification, SEO helpers, and tooltip CSS for VitePress sites",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/bearly",
    "directory": "packages/vitepress-enrich"
  },
  "files": [
    "dist",
    "src",
    "src/terminal-glossary-data.json"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/src/index.js"
    },
    "./glossary": {
      "bun": "./src/glossary.ts",
      "default": "./dist/src/glossary.js"
    },
    "./linkify": {
      "bun": "./src/linkify.ts",
      "default": "./dist/src/linkify.js"
    },
    "./seo": {
      "bun": "./src/seo.ts",
      "default": "./dist/src/seo.js"
    },
    "./validate": {
      "bun": "./src/validate.ts",
      "default": "./dist/src/validate.js"
    },
    "./terminal-glossary": {
      "bun": "./src/terminal-glossary.ts",
      "default": "./dist/src/terminal-glossary.js"
    },
    "./doc-glossary": {
      "bun": "./src/doc-glossary.ts",
      "default": "./dist/src/doc-glossary.js"
    },
    "./css/tooltip.css": "./src/css/tooltip.css",
    "./css/glossary-links.css": "./src/css/glossary-links.css"
  },
  "scripts": {
    "build": "bun build src/index.ts src/glossary.ts src/linkify.ts src/seo.ts src/validate.ts src/entity-engine.ts src/types.ts src/terminal-glossary.ts src/doc-glossary.ts --outdir dist --target node --format esm"
  },
  "peerDependencies": {
    "markdown-it": ">=14",
    "vitepress": ">=1"
  },
  "peerDependenciesMeta": {
    "markdown-it": {
      "optional": true
    },
    "vitepress": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
