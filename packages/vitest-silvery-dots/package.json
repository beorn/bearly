{
  "name": "vitest-silvery-dots",
  "version": "0.1.2",
  "description": "Streaming dot reporter for Vitest, built with Silvery React terminal UI",
  "keywords": [
    "dot-reporter",
    "dots",
    "reporter",
    "silvery",
    "streaming",
    "terminal",
    "test-reporter",
    "tui",
    "vitest",
    "vitest-reporter"
  ],
  "homepage": "https://github.com/beorn/bearly",
  "bugs": {
    "url": "https://github.com/beorn/bearly/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/bearly.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.tsx"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "loggily": ">=0.6.0"
  },
  "devDependencies": {
    "tsdown": "^0.21.7"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "silvery": ">=0.17.0",
    "vitest": ">=4.0.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.tsx",
    "external": [
      "silvery",
      "silvery/*",
      "react",
      "react/jsx-runtime",
      "vitest",
      "vitest/node",
      "loggily"
    ],
    "format": "esm"
  }
}
