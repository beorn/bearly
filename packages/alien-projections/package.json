    "signals",
    "solidjs",
    "sort",
    "tc39-signals",
    "transform"
  ],
  "homepage": "https://github.com/beorn/bearly/tree/main/packages/alien-projections",
  "bugs": {
    "url": "https://github.com/beorn/bearly/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
